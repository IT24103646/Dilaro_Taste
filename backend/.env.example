PORT=5000
# Option A (recommended): local MongoDB (no Docker required)
MONGO_URI=mongodb://127.0.0.1:27017/restaurant_mern

# Option B: no MongoDB install needed (ephemeral DB; data resets on restart)
# USE_IN_MEMORY_DB=true
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=7d

# Optional: comma-separated allowlist. If empty in dev, backend allows any http://localhost:<port>
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174
CORS_ORIGIN=

# Pickup slot capacity (optional)
# Max pickup orders allowed for the exact same `pickup.slotAt` datetime
PICKUP_SLOT_MAX_ORDERS=10

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# SMTP (optional for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=app_password
FROM_EMAIL="Restaurant App <no-reply@restaurant.local>"

# App
APP_BASE_URL=http://localhost:5173

# Reservation reminders (optional) - used by `npm run reminders`
REMINDER_LEAD_HOURS=24
REMINDER_WINDOW_HOURS=24
